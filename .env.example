# ── App ──────────────────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=cs2-llm-bot
LOG_LEVEL=INFO

# ── Database / cache / object storage ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/cs2bot
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=minio
OBJECT_STORAGE_SECRET_KEY=minio123
OBJECT_STORAGE_BUCKET=cs2bot

# ── Polza.ai (OpenAI-compatible LLM) ─────────────────────────────────
POLZA_API_KEY=replace_me
POLZA_BASE_URL=https://polza.ai/api/v1
# chat = strong (explanations, post-mortems, daily review); fast = cheap (news
# classification). gpt-5.2 is a flagship at ~1/7 the price of gpt-5.5 on Polza.
POLZA_CHAT_MODEL=openai/gpt-5.2
# gpt-5-nano: GPT-5-gen, prompt 4.7 vs gpt-4.1-mini's 149 RUB/M — ~32x cheaper
# input, which dominates the (input-heavy) news classification cost.
POLZA_FAST_MODEL=openai/gpt-5-nano
POLZA_EMBEDDING_MODEL=openai/text-embedding-3-large
# Optional: route Polza traffic through a proxy too (leave blank if not needed)
POLZA_PROXY_URL=

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
# Mandatory in this setup (Telegram blocked locally). Format:
#   socks5://user:pass@host:port   or   http://user:pass@host:port
TELEGRAM_PROXY_URL=socks5://user:pass@host:port

# News fetching often needs the proxy too (egress blocked in-region).
NEWS_PROXY_URL=

# ── bo3.gg — primary match/result source (HLTV-grade, open API) ──────
BO3_BASE_URL=https://api.bo3.gg
BO3_PROXY_URL=
BO3_UPCOMING_DAYS=7

# ── PandaScore (legacy; rosters only, no longer the match source) ────
PANDASCORE_API_KEY=replace_me
PANDASCORE_BASE_URL=https://api.pandascore.co
PANDASCORE_TIERS=s,a,b,c,d
PANDASCORE_UPCOMING_DAYS=7

# ── Scheduling (minutes) ─────────────────────────────────────────────
NEWS_COLLECT_INTERVAL_MINUTES=30
MATCH_SCHEDULE_INTERVAL_MINUTES=60
RESULT_COLLECT_INTERVAL_MINUTES=10
PREDICTION_INTERVAL_MINUTES=15
